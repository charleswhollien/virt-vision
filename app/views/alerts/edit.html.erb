<% content_for :title, "Edit Alert" %>

<div class="max-w-2xl">
  <div class="mb-6">
    <%= link_to "&larr; Back to Alerts".html_safe, alerts_path, class: "text-blue-600 hover:underline" %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit Alert: <%= @alert.name %></h1>

  <div class="bg-white rounded-lg shadow p-6">
    <%= form_with model: @alert, local: true, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :name, "Alert Name", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        <% if @alert.errors[:name].any? %>
          <p class="mt-1 text-sm text-red-600"><%= @alert.errors[:name].first %></p>
        <% end %>
      </div>

      <div>
        <%= f.label :condition_type, "Condition Type", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :condition_type, Alert.condition_types.keys.map { |k| [k.humanize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :threshold, "Threshold (%)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :threshold, in: 0..100, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :host_id, "Host", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :host_id, @hosts, :id, :name, { include_blank: "All Hosts" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :vm_id, "VM", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :vm_id, @vms, :id, :name, { include_blank: "All VMs" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :notification_channel, "Notification Channel", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :notification_channel, Alert.notification_channels.keys.map { |k| [k.humanize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div class="flex items-center">
        <%= f.check_box :enabled, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <%= f.label :enabled, "Enabled", class: "ml-2 block text-sm text-gray-900" %>
      </div>

      <div class="pt-4">
        <%= f.submit "Update Alert", class: "w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
