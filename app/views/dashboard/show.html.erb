<% content_for :title, "Dashboard" %>

<h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

<!-- Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0 bg-blue-100 rounded-md p-3">
        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Total Hosts</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:total_hosts] %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0 bg-green-100 rounded-md p-3">
        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Online Hosts</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:online_hosts] %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0 bg-purple-100 rounded-md p-3">
        <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Total VMs</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:total_vms] %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0 bg-emerald-100 rounded-md p-3">
        <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Running VMs</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @stats[:running_vms] %></p>
      </div>
    </div>
  </div>
</div>

<!-- Hosts Overview -->
<div class="bg-white rounded-lg shadow mb-8">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Hosts Overview</h2>
  </div>
  <div class="p-6">
    <% if @hosts.empty? %>
      <p class="text-gray-500 text-center py-8">No hosts configured yet. <%= link_to "Add your first host", new_host_path, class: "text-blue-600 hover:underline" %></p>
    <% else %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @hosts.each do |host| %>
          <div class="border rounded-lg p-4 <%= 'border-green-200 bg-green-50' if host.online? %> <%= 'border-red-200 bg-red-50' if host.offline? || host.error? %>">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-medium text-gray-900"><%= host.name %></h3>
              <span class="px-2 py-1 text-xs rounded-full <%= 'bg-green-100 text-green-800' if host.online? %> <%= 'bg-red-100 text-red-800' if host.offline? || host.error? %>">
                <%= host.status %>
              </span>
            </div>
            <p class="text-sm text-gray-500"><%= host.hostname %></p>
            <p class="text-xs text-gray-400 mt-1"><%= host.vms.count %> VMs</p>
            <div class="mt-3 flex gap-2">
              <%= link_to "View", host_path(host), class: "text-sm text-blue-600 hover:underline" %>
              <%= link_to "Sync", sync_host_path(host), method: :post, class: "text-sm text-gray-600 hover:underline" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- VMs Overview -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-900">Virtual Machines</h2>
    <%= link_to "View All", vms_path, class: "text-sm text-blue-600 hover:underline" %>
  </div>
  <div class="p-6">
    <% if @vms.empty? %>
      <p class="text-gray-500 text-center py-8">No virtual machines found</p>
    <% else %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Host</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">CPU</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Memory</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @vms.limit(10).each do |vm| %>
            <tr>
              <td class="px-4 py-3 text-sm font-medium text-gray-900">
                <%= link_to vm.name, vm_path(vm), class: "text-blue-600 hover:underline" %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= vm.host.name %></td>
              <td class="px-4 py-3 text-sm">
                <span class="px-2 py-1 text-xs rounded-full <%=
                  'bg-green-100 text-green-800' if vm.running? %> <%=
                  'bg-yellow-100 text-yellow-800' if vm.paused? %> <%=
                  'bg-red-100 text-red-800' if vm.stopped? || vm.crashed? %>">
                  <%= vm.status %>
                </span>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= vm.cpu_count %> cores</td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= number_to_human_size(vm.memory_mb.to_i * 1024 * 1024) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
