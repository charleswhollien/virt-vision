<% content_for :title, "Hosts" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Hosts</h1>
  <%= link_to "Add Host", new_host_path, class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors" %>
</div>

<div class="bg-white rounded-lg shadow">
  <% if @hosts.empty? %>
    <div class="p-8 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No hosts</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by adding a new KVM/libvirt host.</p>
      <div class="mt-6">
        <%= link_to "Add Host", new_host_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
      </div>
    </div>
  <% else %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Hostname</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Connection</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">VMs</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Sync</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @hosts.each do |host| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 text-xs rounded-full <%=
                'bg-green-100 text-green-800' if host.online? %> <%=
                'bg-red-100 text-red-800' if host.offline? %> <%=
                'bg-yellow-100 text-yellow-800' if host.error? %>">
                <%= host.status %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to host.name, host_path(host), class: "text-blue-600 hover:underline font-medium" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= host.hostname %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= host.ssh_user %>@<%= host.hostname %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= host.vms.count %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <% if host.last_polled_at %>
                <%= time_ago_in_words(host.last_polled_at) %> ago
              <% else %>
                Never
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= button_to "Sync", sync_host_path(host), method: :post, class: "text-gray-600 hover:text-gray-900 mr-3 inline", form: { class: "inline" } %>
              <%= link_to "Edit", edit_host_path(host), class: "text-blue-600 hover:text-blue-900 mr-3" %>
              <%= button_to "Delete", host_path(host), method: :delete, class: "text-red-600 hover:text-red-900 inline", form: { class: "inline", data: { confirm: "Are you sure?" } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
