<% content_for :title, @host.name %>

<div class="mb-6">
  <%= link_to "&larr; Back to Hosts".html_safe, hosts_path, class: "text-blue-600 hover:underline" %>
</div>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @host.name %></h1>
  <div class="flex gap-3">
    <%= button_to "Test Connection", test_connection_host_path(@host), method: :get, class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors inline", form: { class: "inline" } %>
    <%= button_to "Sync Now", sync_host_path(@host), method: :post, class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors inline", form: { class: "inline" } %>
    <%= link_to "Edit", edit_host_path(@host), class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors" %>
  </div>
</div>

<!-- Host Info Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="text-sm font-medium text-gray-500">Status</h3>
    <p class="mt-2">
      <span class="px-3 py-1 text-sm rounded-full <%=
        'bg-green-100 text-green-800' if @host.online? %> <%=
        'bg-red-100 text-red-800' if @host.offline? %> <%=
        'bg-yellow-100 text-yellow-800' if @host.error? %>">
        <%= @host.status %>
      </span>
    </p>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="text-sm font-medium text-gray-500">Connection</h3>
    <p class="mt-2 text-sm text-gray-900"><%= @host.ssh_user %>@<%= @host.hostname %></p>
    <p class="text-xs text-gray-500"><%= @host.connection_string %></p>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="text-sm font-medium text-gray-500">Last Sync</h3>
    <p class="mt-2 text-sm text-gray-900">
      <% if @host.last_polled_at %>
        <%= @host.last_polled_at.strftime("%Y-%m-%d %H:%M") %>
        <span class="text-gray-500">(<%= time_ago_in_words(@host.last_polled_at) %> ago)</span>
      <% else %>
        Never
      <% end %>
    </p>
  </div>
</div>

<!-- VMs -->
<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">Virtual Machines (<%= @vms.count %>)</h2>
  </div>
  <div class="p-6">
    <% if @vms.empty? %>
      <p class="text-gray-500 text-center py-8">No VMs found on this host. Click "Sync Now" to discover VMs.</p>
    <% else %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">CPU</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Memory</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @vms.each do |vm| %>
            <tr>
              <td class="px-4 py-3 text-sm font-medium text-gray-900">
                <%= link_to vm.name, vm_path(vm), class: "text-blue-600 hover:underline" %>
              </td>
              <td class="px-4 py-3 text-sm">
                <span class="px-2 py-1 text-xs rounded-full <%=
                  'bg-green-100 text-green-800' if vm.running? %> <%=
                  'bg-yellow-100 text-yellow-800' if vm.paused? %> <%=
                  'bg-red-100 text-red-800' if vm.stopped? || vm.crashed? %>">
                  <%= vm.status %>
                </span>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= vm.cpu_count %> cores</td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= number_to_human_size(vm.memory_mb.to_i * 1024 * 1024) %></td>
              <td class="px-4 py-3 text-right text-sm font-medium">
                <%= link_to "View", vm_path(vm), class: "text-blue-600 hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
