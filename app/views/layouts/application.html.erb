<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "VirtVision" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <% if user_signed_in? %>
      <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-64 bg-gray-900 text-white fixed h-full">
          <div class="p-4 border-b border-gray-700">
            <h1 class="text-xl font-bold">VirtVision</h1>
            <p class="text-xs text-gray-400 mt-1">KVM Monitor</p>
          </div>

          <nav class="mt-4">
            <%= link_to root_path, class: "flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition-colors #{'bg-gray-800 text-white' if current_page?(root_path)}" do %>
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
              Dashboard
            <% end %>

            <%= link_to hosts_path, class: "flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition-colors #{'bg-gray-800 text-white' if current_page?(hosts_path)}" do %>
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
              Hosts
            <% end %>

            <%= link_to vms_path, class: "flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition-colors #{'bg-gray-800 text-white' if current_page?(vms_path)}" do %>
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              Virtual Machines
            <% end %>

            <%= link_to alerts_path, class: "flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition-colors #{'bg-gray-800 text-white' if current_page?(alerts_path)}" do %>
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
              Alerts
            <% end %>

            <% if current_user.admin? %>
              <%= link_to users_path, class: "flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition-colors #{'bg-gray-800 text-white' if current_page?(users_path)}" do %>
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                Users
              <% end %>
            <% end %>
          </nav>

          <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-700">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium"><%= current_user.name %></p>
                <p class="text-xs text-gray-400"><%= current_user.email %></p>
              </div>
              <%= button_to logout_path, method: :delete, class: "text-xs text-gray-400 hover:text-white", form: { class: "inline" } do %>
                Logout
              <% end %>
            </div>
          </div>
        </aside>

        <!-- Main Content -->
        <main class="ml-64 flex-1">
          <div class="p-8">
            <% if flash[:notice] %>
              <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800">
                <%= flash[:notice] %>
              </div>
            <% end %>

            <% if flash[:alert] %>
              <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800">
                <%= flash[:alert] %>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <main class="container mx-auto mt-28 px-5 flex">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
