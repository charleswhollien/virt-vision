#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running a rails command, ensure the database is ready
if [ "$1" == "bin/rails" ] || [ "$1" == "./bin/rails" ]; then
  ./bin/rails db:prepare
  ./bin/rails runner "
    u = User.find_or_create_by!(email: 'admin@localhost') do |user|
      user.name = 'Admin'
      user.password = 'admin123'
      user.password_confirmation = 'admin123'
    end
    unless u.authenticate('admin123')
      u.update!(password: 'admin123', password_confirmation: 'admin123')
    end
  " 2>/dev/null || true
fi

exec "$@"
