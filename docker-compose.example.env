# Example environment configuration for Docker
# Copy this file to .env and fill in your values:
#   cp docker-compose.example.env .env

# Generate a new secret key base:
#   openssl rand -hex 64

SECRET_KEY_BASE=your_secret_key_base_here

# Optional: Rails master key for encrypted credentials
# RAILS_MASTER_KEY=your_master_key_from_config_master_key
